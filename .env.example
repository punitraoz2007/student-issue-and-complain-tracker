# GEMINI_API_KEY: Required for Smart Advisor features.
# This system automatically injects this at runtime from secrets.
# Users configure this via the Secrets panel.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# This system automatically injects this at runtime with the service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
